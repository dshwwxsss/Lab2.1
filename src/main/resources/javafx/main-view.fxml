<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="javafx.controller.ReportTableController"
            prefWidth="1200" prefHeight="700">
    <top>
        <VBox spacing="5" style="-fx-padding: 10;">
            <HBox spacing="10">
                <Button text="📥 Загрузить" onAction="#handleLoad"/>
                <Button text="💾 Сохранить" onAction="#handleSave"/>
                <Separator orientation="VERTICAL"/>
                <Button text="➕ Создать" onAction="#handleCreateReport"/>
                <Button text="➕ Строка" onAction="#handleAddLine"/>
                <Separator orientation="VERTICAL"/>
                <Button text="🔄 Refresh" onAction="#refreshTable"/>
            </HBox>
            <HBox spacing="10">
                <Button text="👁️ Показать" onAction="#handleShowReport"/>
                <Button text="📋 Строки" onAction="#handleShowLines"/>
                <Button text="✏️ Изменить" onAction="#handleEditReport"/>
                <Button text="🗑️ Удалить" onAction="#handleDeleteReport"/>
                <Button text="✅ Finalize" onAction="#handleFinalize"/>
                <Button text="✍️ Sign" onAction="#handleSign"/>
                <Button text="📤 Export" onAction="#handleExport"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <TableView fx:id="tableView">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="80"/>
                <TableColumn fx:id="nameColumn" text="Название" prefWidth="250"/>
                <TableColumn fx:id="sampleColumn" text="Образец" prefWidth="200"/>
                <TableColumn fx:id="statusColumn" text="Статус" prefWidth="120"/>
                <TableColumn fx:id="ownerColumn" text="Автор" prefWidth="120"/>
                <TableColumn fx:id="createdAtColumn" text="Создан" prefWidth="200"/>
            </columns>
        </TableView>
    </center>
    <bottom>
        <HBox spacing="10" style="-fx-padding: 5;">
            <ProgressBar fx:id="progressBar" progress="0" maxWidth="200"/>
            <Label fx:id="statusLabel" text="Готов"/>
        </HBox>
    </bottom>
</BorderPane>