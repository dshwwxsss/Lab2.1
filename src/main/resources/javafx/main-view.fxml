<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?> <!-- отступы, элементры управления, контейнеры -->
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- корневой вертикальный  контейнер, пространство имен, контроллер -->
<VBox spacing="10" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="javafx.controller.ReportTableController">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <!-- первая строка, горизонтальная полоса -->
    <ToolBar>
        <Button text="Обновить" onAction="#refreshTable"/>
        <Separator orientation="VERTICAL"/>
        <Button text="Сохранить" onAction="#handleSave"/>
        <Separator orientation="VERTICAL"/>
        <Button text="Создать отчёт" onAction="#handleCreateReport"/>
        <Button text="Добавить строку" onAction="#handleAddLine"/>
        <Button text="Редактировать строку" onAction="#handleUpdateLine"/>
        <Button text="Показать отчёт" onAction="#handleShowReport"/>
        <TextField fx:id="searchField" promptText="Поиск..."/>
        <Button text="Найти" onAction="#handleSearch"/>
    </ToolBar>

    <!-- вторая строка, выпадающий список -->
    <ToolBar>
        <Button text="Редактировать название/образец" onAction="#handleEditReport"/>
        <Button text="Удалить отчёт" onAction="#handleDeleteReport"/>
        <Button text="Удалить строку" onAction="#handleDeleteLine"/>
        <Separator orientation="VERTICAL"/>
        <Button text="Финализировать" onAction="#handleFinalize"/>
        <Button text="Подписать" onAction="#handleSign"/>
        <Button text="Список образцов" onAction="#handleShowSamples"/>
        <Separator orientation="VERTICAL"/>
        <ComboBox fx:id="filterComboBox" promptText="Фильтр по статусу"/>
    </ToolBar>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <ProgressBar fx:id="progressBar" prefWidth="200" visible="false"/>
        <Label fx:id="statusLabel" text="Отчётов: 0"/> <!-- текстовая метка -->
    </HBox>

    <TableView fx:id="tableView" VBox.vgrow="ALWAYS"> <!--идентификатор для доступа из контроллера, вертикаль -->
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/> <!--колонки автоматически подстраиваются под общую ширину таблицы -->
        </columnResizePolicy>
    </TableView>
</VBox>