<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="javafx.controller.ReportTableController">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <!-- Первая строка кнопок -->
    <ToolBar>
        <Button text="Обновить" onAction="#refreshTable"/>
        <Separator orientation="VERTICAL"/>
        <Button text="Сохранить" onAction="#handleSave"/>
        <Separator orientation="VERTICAL"/>
        <Button text="Создать отчёт" onAction="#handleCreateReport"/>
        <Button text="Добавить строку" onAction="#handleAddLine"/>
        <Button text="Редактировать строку" onAction="#handleUpdateLine"/>
        <Button text="Показать отчёт" onAction="#handleShowReport"/>
    </ToolBar>

    <!-- Вторая строка кнопок -->
    <ToolBar>
        <Button text="Редактировать название/образец" onAction="#handleEditReport"/>
        <Button text="Удалить отчёт" onAction="#handleDeleteReport"/>
        <Button text="Удалить строку" onAction="#handleDeleteLine"/>
        <Separator orientation="VERTICAL"/>
        <Button text="Финализировать" onAction="#handleFinalize"/>
        <Button text="Подписать" onAction="#handleSign"/>
        <Button text="Список образцов" onAction="#handleShowSamples"/>
        <Separator orientation="VERTICAL"/>
        <ComboBox fx:id="filterComboBox" promptText="Фильтр по статусу"/>
    </ToolBar>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <ProgressBar fx:id="progressBar" prefWidth="200" visible="false"/>
        <Label fx:id="statusLabel" text="Отчётов: 0"/>
    </HBox>

    <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>
</VBox>